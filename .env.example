# =============================================================================
# App Cultivo — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores
# cp .env.example .env

# -----------------------------------------------------------------------------
# Banco de Dados (MySQL)
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://cultivo:senha_segura@localhost:3306/cultivo

# -----------------------------------------------------------------------------
# Autenticação JWT
# Gere um segredo seguro com: openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_SECRET=seu-segredo-super-secreto-minimo-32-caracteres-aqui

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
# Desenvolvimento local:
# NODE_ENV=development
# PORT=3000
# DOMAIN=localhost:3000

# Produção:
NODE_ENV=production
PORT=3000
DOMAIN=seu-dominio.com

# -----------------------------------------------------------------------------
# Web Push Notifications (VAPID)
# Gere novas chaves com:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=sua-chave-publica-vapid-aqui
VAPID_PRIVATE_KEY=sua-chave-privada-vapid-aqui
VAPID_EMAIL=mailto:admin@seu-dominio.com

# =============================================================================
# ARMAZENAMENTO
# =============================================================================
# As fotos são salvas diretamente no disco do servidor, na pasta /uploads
# Não é necessária nenhuma configuração adicional!
# As imagens ficam disponíveis em: http://seu-servidor/uploads/...
# =============================================================================
