# =============================================================================
# App Cultivo — Variáveis de Ambiente (Versão Servidor Independente)
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores
# cp .env.example .env

# -----------------------------------------------------------------------------
# Banco de Dados (MySQL)
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://cultivo:senha_segura@localhost:3306/cultivo

# -----------------------------------------------------------------------------
# Autenticação JWT
# Gere um segredo seguro com: openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_SECRET=seu-segredo-super-secreto-minimo-32-caracteres-aqui

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
DOMAIN=localhost:3000

# -----------------------------------------------------------------------------
# LLM / IA (Opcional)
# Necessário para funcionalidades de análise inteligente
# Compatível com OpenAI, Groq, Ollama (local), ou qualquer API OpenAI-compatible
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Para usar Ollama localmente (gratuito, sem API key):
# OPENAI_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# Para usar Groq (gratuito com limites):
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant

# -----------------------------------------------------------------------------
# Google Maps (Opcional)
# Necessário para funcionalidades de localização
# -----------------------------------------------------------------------------
# GOOGLE_MAPS_API_KEY=AIza...

# =============================================================================
# ARMAZENAMENTO
# =============================================================================
# As fotos são salvas diretamente no disco do servidor, na pasta /uploads
# Não é necessária nenhuma configuração adicional!
# As imagens ficam disponíveis em: http://seu-servidor/uploads/...
# =============================================================================
