# =============================================================================
# App Cultivo — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores
# cp .env.example .env

# -----------------------------------------------------------------------------
# Banco de Dados (MySQL)
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://cultivo:senha_segura@localhost:3306/cultivo

# -----------------------------------------------------------------------------
# Autenticação JWT
# Gere um segredo seguro com: openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_SECRET=seu-segredo-super-secreto-minimo-32-caracteres-aqui

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
# Desenvolvimento local:
# NODE_ENV=development
# PORT=3000
# DOMAIN=localhost:3000

# Produção:
NODE_ENV=production
PORT=3000
DOMAIN=seu-dominio.com

# -----------------------------------------------------------------------------
# Web Push Notifications (VAPID)
# Gere novas chaves com:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=sua-chave-publica-vapid-aqui
VAPID_PRIVATE_KEY=sua-chave-privada-vapid-aqui
VAPID_EMAIL=mailto:admin@seu-dominio.com

# =============================================================================
# ARMAZENAMENTO
# =============================================================================
# As fotos são salvas diretamente no disco do servidor, na pasta /uploads
# Não é necessária nenhuma configuração adicional!
# As imagens ficam disponíveis em: http://seu-servidor/uploads/...
# =============================================================================

# =============================================================================
# MOBILE / CAPACITOR
# =============================================================================
# URL absoluta da API remota usada pelo build mobile (iOS/Android via Capacitor).
# Em prod: https://app.cultivo.pro
# Em dev: deixe vazio para mobile usar mesma origem do dev server.
VITE_API_BASE_URL=

# Habilita contas de teste (pro@cultivo.pro, team@cultivo.pro, free@cultivo.pro)
# e o helper window.__setDevPlan no console. Útil pra testar UX dos planos sem
# RevenueCat. NUNCA habilitar em build de release (App Store / Play Store) —
# senão atacante registra os emails e vira Pro de graça.
VITE_ENABLE_TEST_ACCOUNTS=true

# =============================================================================
# REVENUECAT (in-app subscriptions iOS/Android)
# =============================================================================
# Servidor — recebe webhook do RC e consulta REST API
RC_WEBHOOK_SECRET=
RC_SECRET_KEY=
# Cliente Capacitor — chaves públicas por plataforma
# Pegue em https://app.revenuecat.com → Project → API Keys → Public app-specific
VITE_REVENUECAT_IOS_KEY=
VITE_REVENUECAT_ANDROID_KEY=

# =============================================================================
# EMAIL (Resend — transactional email)
# =============================================================================
# Chave de API do Resend para envio de emails transacionais.
# Pegue em https://resend.com/api-keys
# Se vazio, emails são logados no console (dev sem conta funciona normal).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL pública do app — usada nos links de "Redefinir senha" nos emails.
# Em produção: https://app.cultivo.pro
# Em dev local: http://localhost:3000
APP_URL=https://app.cultivo.pro

# =============================================================================
# SENTRY (crash reporting + error tracking)
# =============================================================================
# DSN público (pode aparecer no bundle do client — é design do Sentry).
# Pegue em https://sentry.io → Project → Settings → Client Keys (DSN)
# Free tier: 5k errors/mês, 50 replays/mês, retention indefinido.
# Se vazio, Sentry é no-op silencioso (dev local sem conta funciona normal).
# Setup completo em SENTRY-SETUP.md
VITE_SENTRY_DSN=

# Versão do app pra release tracking no Sentry (opcional mas útil).
# Recomendado: sincronizar com package.json ou commit SHA do build.
# Ex: VITE_APP_VERSION=2.0.0 ou VITE_APP_VERSION=$(git rev-parse --short HEAD)
VITE_APP_VERSION=2.0.0
