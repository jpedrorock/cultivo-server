<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!--
        Edge-to-edge ready (Android 15+ vai exigir isso pra apps targetSdk 35+).
        Configura status bar e nav bar transparentes; conteúdo do app ocupa
        a tela inteira incluindo área dos system bars.

        O CSS do app (env(safe-area-inset-*)) já garante que o conteúdo
        importante fica fora das áreas dos system bars.

        windowLightStatusBar=false porque app é dark theme — ícones do status
        bar ficam BRANCOS sobre fundo escuro do nosso app.
    -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>

        <!-- Edge-to-edge: conteúdo embaixo dos system bars -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- App é dark theme: ícones dos system bars ficam BRANCOS -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Enforça contraste atrás de nav bar transparente em Android 10+
             (sem isso, ícones podem sumir se conteúdo for da mesma cor) -->
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>
</resources>