# ============================================
# CONFIGURAÇÃO DE PRODUÇÃO - CULTIVO SERVER
# ============================================
# Copie este arquivo para .env e configure com seus valores reais

# Banco de Dados MySQL
DATABASE_URL=mysql://cultivo_user:senha_super_segura_aqui@db:3306/cultivo
MYSQL_ROOT_PASSWORD=root_senha_super_segura_aqui
MYSQL_USER=cultivo_user
MYSQL_PASSWORD=senha_super_segura_aqui

# Autenticação JWT
# IMPORTANTE: Gere um segredo aleatório com pelo menos 32 caracteres
# Comando: openssl rand -base64 32
JWT_SECRET=gere-um-segredo-aleatorio-com-32-caracteres-aqui

# Armazenamento S3 / MinIO
# Se usar MinIO no mesmo servidor:
S3_ENDPOINT=https://s3.seu-dominio.com
# Se usar MinIO em outro servidor:
# S3_ENDPOINT=https://minio.seu-dominio.com
S3_BUCKET=cultivo-fotos
S3_ACCESS_KEY=sua-chave-acesso-segura
S3_SECRET_KEY=sua-chave-secreta-super-segura
S3_REGION=us-east-1

# MinIO (se usar no mesmo servidor)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=senha_super_segura_aqui

# Aplicação
NODE_ENV=production
PORT=3000
DOMAIN=cultivo.seu-dominio.com

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. Nunca commite este arquivo no Git
# 2. Use senhas fortes e aleatórias
# 3. Backup regular do banco de dados
# 4. Configure SSL/HTTPS com Let's Encrypt
# 5. Configure firewall para aceitar apenas portas necessárias
# 6. Monitore logs e performance regularmente
