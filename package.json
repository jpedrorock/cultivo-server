{
  "name": "cultivo-server",
  "version": "2.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:seed": "node server/seed.mjs",
    "db:reset": "node server/seed.mjs",
    "db:restart": "node server/db-reset.mjs",
    "db:migrate": "tsx server/_core/dbMigrations.ts",
    "db:generate": "drizzle-kit generate",
    "backfill:esp-variants": "node server/backfill-esp-variants.mjs",
    "mobile:build": "VITE_ENABLE_TEST_ACCOUNTS=true vite build && cap sync",
    "mobile:ios": "VITE_ENABLE_TEST_ACCOUNTS=true vite build && cap sync ios && cap open ios",
    "mobile:android": "VITE_ENABLE_TEST_ACCOUNTS=true vite build && cap sync android && cap open android",
    "mobile:run:ios": "VITE_ENABLE_TEST_ACCOUNTS=true vite build && cap sync ios && cap run ios",
    "mobile:run:android": "VITE_ENABLE_TEST_ACCOUNTS=true vite build && cap sync android && cap run android",
    "mobile:build:release": "vite build && cap sync"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
