    "react-simple-pull-to-refresh": "^1.3.4",
    "react-swipeable": "^7.0.2",
    "recharts": "^3.7.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "superjson": "^1.13.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "wouter": "^3.3.5",
    "zod": "^4.1.12"
